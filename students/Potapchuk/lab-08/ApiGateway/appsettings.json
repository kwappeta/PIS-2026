{
  "ReverseProxy": {
    "Routes": {
      "requests": {
        "ClusterId": "requestService",
        "Match": { "Path": "/api/requests/{**catch-all}" }
      },
      "groups": {
        "ClusterId": "groupService",
        "Match": { "Path": "/api/groups/{**catch-all}" }
      }
    },
    "Clusters": {
      "requestService": { "Destinations": { "dest1": { "Address": "http://requestservice:8080" } } },
      "groupService": { "Destinations": { "dest1": { "Address": "http://groupservice:8080" } } }
    }
  }
}