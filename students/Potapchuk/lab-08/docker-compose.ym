version: '3.8'

services:
  rabbitmq:
    image: rabbitmq:3-management
    ports:
      - "5672:5672"
      - "15672:15672"

  request-service:
    build: ./services/RequestService
    ports:
      - "8081:8080"

  group-service:
    build: ./services/GroupService
    ports:
      - "8082:8080"

  notification-service:
    build: ./services/NotificationService
    ports:
      - "8083:8080"

  api-gateway:
    build: ./ApiGateway
    ports:
      - "5000:5000"